# Copy this file to .env and fill in the values before running docker compose up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ticreactoe
POSTGRES_USER=ticreactoe
POSTGRES_PASSWORD=changeme

# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=changeme

# Comma-separated list of hostnames the server responds to
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

DJANGO_DEBUG=False

# Comma-separated list of origins trusted for CSRF (must include your domain)
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Base URL of the frontend, used in email links sent by allauth
DJANGO_FRONTEND_URL=https://yourdomain.com

DJANGO_TIME_ZONE=America/New_York

# ── App ───────────────────────────────────────────────────────────────────────
# Your domain name — Caddy uses this to obtain a Let's Encrypt certificate
DOMAIN=yourdomain.com
